APP_NAME=Finance Dashboard API
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./data/finance.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/finance_db
JWT_SECRET_KEY=REPLACE_WITH_A_64_BYTE_HEX_SECRET_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=30
JWT_REFRESH_TOKEN_TTL_DAYS=7
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_LENGTH=128
BCRYPT_ROUNDS=12
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_WRITE=30/minute
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
HSTS_MAX_AGE_SECONDS=31536000
PAGINATION_DEFAULT_PAGE_SIZE=20
PAGINATION_MAX_PAGE_SIZE=100
LOG_LEVEL=INFO
LOG_FORMAT=console
BOOTSTRAP_ADMIN_EMAIL=admin@finance.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
